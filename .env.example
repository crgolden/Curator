# Copy this file to .env and fill in real values. curator.settings.Settings.from_config() resolves every
# one of these (arg -> env var -> .env file, see curator.persistence.config); none of them are ever
# hardcoded.

# --- Required -------------------------------------------------------------------------------------------

# Identity's OIDC authority base URL. Used both to fetch the JWKS (for bearer-token signature validation)
# and as the expected `iss` claim on every validated access token.
OIDC_AUTHORITY=https://localhost:7261

# Fernet key encrypting stored PSN tokens at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CURATOR_TOKEN_KEY=

# PostgreSQL connection URL. Local dev targets this machine's own PostgreSQL 17 service
# (postgresql-x64-17), not the shared crgolden.com production server.
CURATOR_DATABASE_URL=postgresql://curator_app:<password>@localhost:5432/curator

# --- Optional: telemetry (both legs no-op when unset) ----------------------------------------------------

# Grafana Alloy OTLP gRPC endpoint (traces + metrics). Unset disables this leg entirely.
# AlloyEndpoint=

# Elasticsearch structured logging. All three must be set together, or this leg stays disabled.
# ElasticsearchNode=
# ElasticsearchUsername=
# ElasticsearchPassword=

# --- Optional: enrichment (each unset key just disables its own signal) ----------------------------------

# RawgApiKey=
# OpenCriticRapidApiKey=

# --- Optional: background jobs (unset disables the queue consumer + job-publishing routes) ---------------

# ServiceBusConnectionString=
